# HireWire — Environment Variables
# Copy this to .env.local — never commit .env.local to git

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Used by FastAPI only (not Next.js) ───────────────────────
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # bypasses RLS — keep secret!

# ── Resend (Phase 3) ─────────────────────────────────────────
# RESEND_API_KEY=re_...

# ── Google OAuth (Phase 4) ───────────────────────────────────
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...


# ══════════════════════════════════════════════════════════════
# PHASE 1 SETUP CHECKLIST
# ══════════════════════════════════════════════════════════════
#
# 1. CREATE SUPABASE PROJECT
#    → https://supabase.com → New project
#    → Copy URL and anon key into this file
#
# 2. RUN THE SCHEMA
#    → Supabase Dashboard → SQL Editor → paste hirewire_schema.sql → Run
#
# 3. ENABLE AUTH PROVIDERS
#    → Supabase Dashboard → Authentication → Providers
#    → Enable: Email (confirm emails ON)
#    → Enable: Google (needs OAuth credentials — see step 4)
#
# 4. GOOGLE OAUTH SETUP (for Google sign-in button)
#    → https://console.cloud.google.com → New project
#    → APIs & Services → Credentials → OAuth 2.0 Client ID
#    → Application type: Web application
#    → Authorized redirect URIs:
#       https://your-project-ref.supabase.co/auth/v1/callback
#    → Copy Client ID + Secret into Supabase Auth → Google provider settings
#
# 5. INSTALL DEPENDENCIES
#    npm install @supabase/ssr @supabase/supabase-js
#
# 6. RUN LOCALLY
#    npm run dev → visit http://localhost:3000/auth
#
# 7. CONFIRM IT WORKS
#    □ Email signup sends confirmation email
#    □ After confirming, login redirects to /dashboard
#    □ Google OAuth completes and lands on /dashboard
#    □ Hitting /dashboard while logged out redirects to /auth
#    □ Hitting /auth while logged in redirects to /dashboard
#
# ══════════════════════════════════════════════════════════════
