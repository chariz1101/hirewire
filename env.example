# hirewire — Next.js Frontend
# File: .env.local (root of the hirewire repo)
# Never commit this file. It's already in .gitignore by default in Next.js.

# ── Supabase ──────────────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Google OAuth (for Gmail connect in Phase 4) ───────────────────────────
# Google Cloud Console → APIs & Services → Credentials → your OAuth 2.0 Client
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── App URL ───────────────────────────────────────────────────────────────
# Local dev: http://localhost:3000
# Production (set this in Vercel dashboard, not here): https://hirewire.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
